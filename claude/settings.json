{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Write",
      "WebFetch",
      "WebSearch",
      "mcp__*"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status-line.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "playground@claude-plugins-official": true
  },
  "effortLevel": "high"
}
